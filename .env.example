# ── Variáveis de ambiente para o projeto ExtraMed Gestão ──────────────────────
#
# Copie este arquivo para .env.local para desenvolvimento local.
# Em produção, configure no painel Vercel: Settings → Environment Variables.
#
# NUNCA commite .env.local com valores reais.

# URL do projeto Supabase (sem barra no final)
SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Chave service_role — SOMENTE para funções serverless (api/).
# JAMAIS use esta chave no HTML ou em qualquer código que rode no cliente.
# Encontre em: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Origens permitidas para o formulário público (CORS), separadas por vírgula.
# Em desenvolvimento, deixe vazio para permitir localhost.
# Em produção, use o domínio real: https://extramed-gestao.vercel.app,https://meudominio.com
ALLOWED_ORIGINS=https://extramed-gestao.vercel.app

# ── Nota sobre a SUPABASE_KEY (anon key) ──────────────────────────────────────
#
# A chave anon do Supabase (que aparece no index.html) é PÚBLICA por design.
# Ela é equivalente a uma chave de leitura restrita — quem tem acesso ao quê
# é controlado pelas políticas RLS no banco de dados, não pela chave em si.
# Documentação: https://supabase.com/docs/guides/api/api-keys
#
# Mesmo assim, mantenha RLS habilitado em todas as tabelas para que a anon key
# não possa acessar dados além do necessário.
